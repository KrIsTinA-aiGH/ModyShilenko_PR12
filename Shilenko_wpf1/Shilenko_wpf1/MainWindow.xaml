<Window x:Class="Shilenko_wpf1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Руль" 
        Height="710" 
        Width="1000" 
        MinHeight="710" 
        MinWidth="1000" 
        WindowStartupLocation="CenterScreen" 
        Icon="/Resources/icon.ico"
        Background="#1a1a1a">

    <Window.Resources>
        <!-- Кисти темы -->
        <SolidColorBrush x:Key="BgDarkBrush" Color="#1a1a1a"/>
        <SolidColorBrush x:Key="BgHeaderBrush" Color="#2d2d2d"/>
        <SolidColorBrush x:Key="AccentRedBrush" Color="#c41e3a"/>
        <SolidColorBrush x:Key="AccentRedHoverBrush" Color="#e02a4a"/>
        <SolidColorBrush x:Key="TextMainBrush" Color="#e0e0e0"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#404040"/>

        <!-- Стиль для кнопки Назад -->
        <Style x:Key="BackButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentRedBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,6"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0,0,15,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentRedHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель (тёмная) -->
        <Grid Grid.Row="0" Background="{StaticResource BgHeaderBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Логотип -->
            <Image Grid.Column="0" 
                   HorizontalAlignment="Left" 
                   Margin="15,8,0,8" 
                   Width="45" 
                   Source="/Resources/logo.png"
                   Stretch="Uniform"/>

            <!-- Кнопка Назад -->
            <Button Grid.Column="2" 
                    x:Name="btnBack" 
                    Content="Назад" 
                    HorizontalAlignment="Right" 
                    Cursor="Hand" 
                    Click="btnBack_Click"
                    Style="{StaticResource BackButtonStyle}"/>
        </Grid>

        <!-- Фрейм для страниц -->
        <Frame x:Name="fr_content" 
               Grid.Row="1" 
               NavigationUIVisibility="Hidden" 
               ContentRendered="frame_Content"
               Background="{StaticResource BgDarkBrush}"/>
    </Grid>
</Window>