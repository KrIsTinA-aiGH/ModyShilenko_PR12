<Window x:Class="Shilenko_wpf1.Pages.ResetPasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новый пароль" 
        Width="402.829" 
        Height="305.163"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1a1a1a"
        WindowStyle="SingleBorderWindow"
        BorderBrush="#404040"
        BorderThickness="1">

    <Window.Resources>
        <!-- Кисти темы -->
        <SolidColorBrush x:Key="BgDarkBrush" Color="#1a1a1a"/>
        <SolidColorBrush x:Key="BgCardBrush" Color="#2d2d2d"/>
        <SolidColorBrush x:Key="InputBackgroundBrush" Color="#3a3a3a"/>
        <SolidColorBrush x:Key="InputBorderBrush" Color="#404040"/>
        <SolidColorBrush x:Key="AccentRedBrush" Color="#c41e3a"/>
        <SolidColorBrush x:Key="AccentRedHoverBrush" Color="#e02a4a"/>
        <SolidColorBrush x:Key="AccentRedPressedBrush" Color="#9a172d"/>
        <SolidColorBrush x:Key="TextMainBrush" Color="#e0e0e0"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#a0a0a0"/>

        <!-- Стиль для заголовков полей -->
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <!-- Стиль для PasswordBox -->
        <Style x:Key="PasswordInputStyle" TargetType="PasswordBox">
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type PasswordBox}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentRedBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для основной кнопки -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentRedBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="20,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentRedHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentRedPressedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для вторичной кнопки -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#404040"/>
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#505050"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#303030"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <!-- Карточка диалога -->
        <Border Background="{StaticResource BgCardBrush}"
                CornerRadius="8"
                Padding="25"
                BorderBrush="{StaticResource InputBorderBrush}"
                BorderThickness="1">

            <StackPanel>
                <!-- Поле нового пароля -->
                <TextBlock Text="Новый пароль:" Style="{StaticResource FieldLabelStyle}"/>
                <PasswordBox x:Name="pbNewPassword" Style="{StaticResource PasswordInputStyle}"/>

                <!-- Поле подтверждения пароля -->
                <TextBlock Text="Подтвердите пароль:" Style="{StaticResource FieldLabelStyle}"/>
                <PasswordBox x:Name="pbConfirmPassword" Style="{StaticResource PasswordInputStyle}"/>

                <!-- Кнопки -->
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Right" 
                            Margin="0,10,0,0">
                    <Button Content="Отмена" 
                            Width="80" 
                            Margin="0,0,10,0"
                            Click="btnCancel_Click"
                            Style="{StaticResource SecondaryButtonStyle}"/>
                    <Button Content="Сохранить" 
                            Width="80" 
                            Click="btnSave_Click"
                            Style="{StaticResource PrimaryButtonStyle}"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>