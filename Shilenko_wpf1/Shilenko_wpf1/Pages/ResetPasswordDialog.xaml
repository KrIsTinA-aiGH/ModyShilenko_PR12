<Window x:Class="Shilenko_wpf1.Pages.ResetPasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новый пароль" 
        Width="400" 
        Height="250"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">

    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Новый пароль:" 
                       Margin="0,0,0,5"/>

            <PasswordBox x:Name="pbNewPassword" 
                         Margin="0,0,0,10"
                         Height="30"/>

            <TextBlock Text="Подтвердите пароль:" 
                       Margin="0,0,0,5"/>

            <PasswordBox x:Name="pbConfirmPassword" 
                         Margin="0,0,0,10"
                         Height="30"/>

            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Right" 
                        Margin="0,20,0,0">
                <Button Content="Отмена" 
                        Width="80" 
                        Margin="0,0,10,0"
                        Click="btnCancel_Click"/>
                <Button Content="Сохранить" 
                        Width="80" 
                        Click="btnSave_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>