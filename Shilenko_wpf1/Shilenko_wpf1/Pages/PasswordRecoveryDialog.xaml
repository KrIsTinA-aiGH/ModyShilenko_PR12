<Window x:Class="Shilenko_wpf1.Pages.PasswordRecoveryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Восстановление пароля" 
        Width="400" 
        Height="200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">

    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Введите ваш email для восстановления пароля:" 
                       Margin="0,0,0,10"
                       TextWrapping="Wrap"/>

            <TextBox x:Name="tbEmail"  
                     Margin="0,0,0,10"
                     Height="30"/>

            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Right" 
                        Margin="0,20,0,0">
                <Button Content="Отмена" 
                        Width="80" 
                        Margin="0,0,10,0"
                        Click="btnCancel_Click"/>
                <Button Content="Отправить код" 
                        Width="100" 
                        Click="btnSendCode_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>