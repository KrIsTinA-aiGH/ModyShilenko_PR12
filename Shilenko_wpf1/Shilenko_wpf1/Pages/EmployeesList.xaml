<Page x:Class="Shilenko_wpf1.Pages.EmployeesList"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Shilenko_wpf1.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="900"
      Title="Список сотрудников"
      Loaded="Page_Loaded"
      Background="#1a1a1a">

    <Page.Resources>
        <!-- Кисти темы -->
        <SolidColorBrush x:Key="BgDarkBrush" Color="#1a1a1a"/>
        <SolidColorBrush x:Key="BgPanelBrush" Color="#2d2d2d"/>
        <SolidColorBrush x:Key="BgCardBrush" Color="#3a3a3a"/>
        <SolidColorBrush x:Key="AccentRedBrush" Color="#c41e3a"/>
        <SolidColorBrush x:Key="AccentRedHoverBrush" Color="#e02a4a"/>
        <SolidColorBrush x:Key="AccentRedPressedBrush" Color="#9a172d"/>
        <SolidColorBrush x:Key="TextMainBrush" Color="#e0e0e0"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#a0a0a0"/>
        <SolidColorBrush x:Key="InputBorderBrush" Color="#404040"/>
        <SolidColorBrush x:Key="GridHeaderBrush" Color="#4a4a4a"/>
        <SolidColorBrush x:Key="GridRowHoverBrush" Color="#4a3a3a"/>
        <SolidColorBrush x:Key="GridRowSelectedBrush" Color="#c41e3a"/>
        <SolidColorBrush x:Key="PopupBackgroundBrush" Color="#2d2d2d"/>

        <!-- Стиль для заголовков страниц -->
        <Style x:Key="PageTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <!-- Стиль для подписей полей -->
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="5,0"/>
        </Style>

        <!-- Стиль для TextBox -->
        <Style x:Key="ThemeTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentRedBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Простой совместимый стиль для ComboBox -->
        <Style x:Key="ThemeComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentRedBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для элементов ComboBox (выпадающий список) -->
        <Style x:Key="ThemeComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{StaticResource PopupBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="Padding" Value="6,4"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentRedBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentRedPressedBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для кнопки -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentRedBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="20,0,5,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentRedHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentRedPressedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для заголовков GridView -->
        <Style x:Key="GridViewHeaderStyle" TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="{StaticResource GridHeaderBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <!-- Стиль для ListViewItem -->
        <Style x:Key="ThemeListViewItemStyle" TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource GridRowHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource GridRowSelectedBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для статусной строки -->
        <Style x:Key="StatusBarStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="10"/>
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource BgDarkBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="Список сотрудников" Style="{StaticResource PageTitleStyle}"/>

        <!-- Панель поиска и фильтрации -->
        <Border Grid.Row="1" 
                Background="{StaticResource BgPanelBrush}"
                Padding="10"
                Margin="10,0,10,10"
                CornerRadius="6"
                BorderBrush="{StaticResource InputBorderBrush}"
                BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Поиск по ФИО:" Style="{StaticResource FieldLabelStyle}"/>
                <TextBox x:Name="txtSearch" 
                         Width="200" 
                         Style="{StaticResource ThemeTextBoxStyle}"
                         TextChanged="txtSearch_TextChanged"/>

                <TextBlock Text="Фильтр по должности:" 
                           Style="{StaticResource FieldLabelStyle}"
                           Margin="20,0,5,0"/>
                <ComboBox x:Name="cmbPositionFilter" 
                          Width="200" 
                          Style="{StaticResource ThemeComboBoxStyle}"
                          ItemContainerStyle="{StaticResource ThemeComboBoxItemStyle}"
                          SelectionChanged="cmbPositionFilter_SelectionChanged"/>

                <Button x:Name="btnAddEmployee" 
                        Content="Добавить сотрудника" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="btnAddEmployee_Click"/>
            </StackPanel>
        </Border>

        <!-- Список сотрудников -->
        <Border Grid.Row="2" 
                Background="{StaticResource BgCardBrush}"
                Margin="10"
                CornerRadius="6"
                BorderBrush="{StaticResource InputBorderBrush}"
                BorderThickness="1">
            <ListView x:Name="lvEmployees"
                      ItemContainerStyle="{StaticResource ThemeListViewItemStyle}"
                      Background="Transparent"
                      BorderThickness="0"
                      MouseDoubleClick="lvEmployees_MouseDoubleClick">
                <ListView.View>
                    <GridView ColumnHeaderContainerStyle="{StaticResource GridViewHeaderStyle}">
                        <GridViewColumn Header="ID" Width="50" 
                                        DisplayMemberBinding="{Binding EmployeeID}"/>
                        <GridViewColumn Header="Фамилия" Width="120" 
                                        DisplayMemberBinding="{Binding LastName}"/>
                        <GridViewColumn Header="Имя" Width="120" 
                                        DisplayMemberBinding="{Binding FirstName}"/>
                        <GridViewColumn Header="Должность" Width="150" 
                                        DisplayMemberBinding="{Binding EmployeePositions.PositionName}"/>
                        <GridViewColumn Header="Дата приёма" Width="100" 
                                        DisplayMemberBinding="{Binding HireDate, StringFormat=\{0:dd.MM.yyyy\}}"/>
                        <GridViewColumn Header="Телефон" Width="120" 
                                        DisplayMemberBinding="{Binding Phone}"/>
                        <GridViewColumn Header="Email" Width="200" 
                                        DisplayMemberBinding="{Binding Email}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <!-- Статусная строка -->
        <TextBlock Grid.Row="3" x:Name="tbStatus" Style="{StaticResource StatusBarStyle}"/>
    </Grid>
</Page>