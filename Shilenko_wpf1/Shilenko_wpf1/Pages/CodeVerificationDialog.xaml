<Window x:Class="Shilenko_wpf1.Pages.CodeVerificationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Подтверждение кода" 
        Width="350" 
        Height="200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">

    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Введите 4-значный код из письма:" 
                       Margin="0,0,0,10"
                       TextWrapping="Wrap"/>

            <TextBox x:Name="tbCode" 
                     MaxLength="4"
                     Margin="0,0,0,10"
                     Height="30"/>

            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Right" 
                        Margin="0,20,0,0">
                <Button Content="Отмена" 
                        Width="80" 
                        Margin="0,0,10,0"
                        Click="btnCancel_Click"/>
                <Button Content="Проверить" 
                        Width="80" 
                        Click="btnVerify_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>